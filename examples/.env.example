# Auto-configured by Mavis on 2026-06-30 for the Prometheus self-learning loop.
# Routes ALL LLM calls (compile, focus, lint, grade, reflect) through the local
# openai-proxy on :8181 (which uses ~/.codex/auth.json ChatGPT tokens).
#
# Producer/grader separation: the producer (compile/focus/lint) uses gpt-5.4-mini.
# The grader (learn-grade + pmpo reflect + sycophancy correction) uses gpt-5.5.
# The critic MUST be smarter than the producer or the loop learns the
# producer's blind spots. See karpathy-loop-continuous-improvement.md §
# "Anti-sycophancy as a structural property".
CLOUD_LLM_URL=http://localhost:8181/v1
LOCAL_LLM_URL=http://localhost:8181/v1
CLOUD_LLM_API_KEY=__USE_PROXY__
LEARN_GRADER_MODEL=gpt-5.5
LEARN_GRADER_URL=http://localhost:8181/v1
LEARN_GRADER_API_KEY=__USE_PROXY__
PK_COMPILE_MODEL=gpt-5.4-mini
PK_LINT_MODEL=gpt-5.4-mini
PK_FOCUS_MODEL=gpt-5.4-mini
PMPO_REFLECT_MODEL=gpt-5.5
PMPO_STRATEGIC_DREAM_MODEL=gpt-5.5
SYCOPHANCY_REFLECT_MODEL=gpt-5.5
